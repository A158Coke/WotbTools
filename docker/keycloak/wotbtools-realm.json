{
  "id": "wotbtools",
  "realm": "wotbtools",
  "displayName": "WoTBTools",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": true,
  "internationalizationEnabled": true,
  "defaultLocale": "zh",
  "supportedLocales": ["zh","en","ru"],
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 86400,
  "ssoSessionMaxLifespan": 604800,
  "roles": {
    "realm": [
      { "name": "wotbtools-admin", "description": "WoTBTools 管理员" },
      { "name": "boost-manager", "description": "陪练管理员" }
    ]
  },
  "clients": [
    {
      "clientId": "wotbtools-web",
      "name": "WoTBTools Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://wotbtools.com/*",
        "https://*.wotbtools.com/*",
        "http://localhost:5173/*",
        "http://localhost:8088/*"
      ],
      "webOrigins": [
        "https://wotbtools.com",
        "https://*.wotbtools.com",
        "http://localhost:5173",
        "http://localhost:8088"
      ]
    }
  ]
}
