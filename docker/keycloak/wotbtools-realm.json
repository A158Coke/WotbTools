{
  "id": "wotbtools",
  "realm": "wotbtools",
  "displayName": "WoTBTools",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": true,
  "internationalizationEnabled": true,
  "defaultLocale": "zh",
  "supportedLocales": ["zh","en","ru"],
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 86400,
  "ssoSessionMaxLifespan": 604800,
  "roles": {
    "realm": [
      { "name": "wotbtools-admin", "description": "WoTBTools 管理员" },
      { "name": "boost-manager", "description": "陪练管理员" },
      { "name": "booster", "description": "打手" }
    ]
  },
  "clients": [
    {
      "clientId": "wotbtools-web",
      "name": "WoTBTools Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://wotbtools.com/*",
        "https://*.wotbtools.com/*",
        "http://localhost:5173/*",
        "http://localhost:8088/*"
      ],
      "webOrigins": [
        "https://wotbtools.com",
        "https://*.wotbtools.com",
        "http://localhost:5173",
        "http://localhost:8088"
      ],
      "protocolMappers": [
        {
          "name": "display-name-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "displayName",
            "claim.name": "displayName",
            "claim.value": "attribute_value",
            "jsonType.label": "String",
            "id.token.claim": true,
            "access.token.claim": true,
            "userinfo.token.claim": true
          }
        }
      ]
    }
  ]
}
